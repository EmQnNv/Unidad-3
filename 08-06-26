Vegetales={
    1:{"Nombre": "Maracuya", "Precio":3000},
    2:{"Nombre": "Pera", "Precio":1500},
    3:{"Nombre": "Zanahoria", "Precio":2000}

}
def Mostrar_Vegetales():
    print("---"*40)

    for key, informacon in Vegetales.items():
        print(f"{key} {informacon}")

    print("---"*40)
def Ingresar_Vegetal():
    print("Cual es el nombre del que deseas agregar?")
    nombre = input()
    print("cuales el precio?")
    precio = int(input())
    nuevokey = list(Vegetales.keys())[-1]### de la "lista" agarra los "4" pero eliimina 1 para que asi sean los que si existen??
    Vegetales[nuevokey+1] = {"Nombre": nombre, "Precio": precio} ##debido a que las keys son solo los numeros del diccionario lo que
    ###pondremos como segundo "parametro" es lo que queremos poner
def Eliminar_Vegetal():
    print("Que quiere eliminar?")    
    Mostrar_Vegetales()
    numero = int(input())
    if numero in Vegetales:
        print("Eliminando!")
        del Vegetales[numero]
def Actualizar_Vegetal():
    Mostrar_Vegetales()
    print("Cual vegetal quieres actualizar su precio?")
    act = int(input())
    if act in Vegetales:
        print("Esto es lo que vas a cambiar")
        print(Vegetales[act])
        print("Dime el nombre")
        CambioNombre = input()
        Vegetales[act]["Nombre"] = CambioNombre
        print("ahora dime el precio")
        cambioPrecio = int(input())
        Vegetales[act]["Precio"] = cambioPrecio



while True:
    try:
        print("1.- Agregar Vegetal")
        print("2.- Mostrar Vegetales ")
        print("3.- Eliminar Vegetal")
        print("4.- Actualizar Vegetal")
        print("5.- Salir")

        op = int(input())
        match op:
            case 1:
                Ingresar_Vegetal()
            case 2:
                Mostrar_Vegetales()
            case 3:
                Eliminar_Vegetal()
            case 4:
                Actualizar_Vegetal()
            case 5:
                print("saliendo mi rei")
                break
            case _:
                print("que wea pusiste wn")
    except Exception as e:
        print("Error", e)